// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// User Model
// ============================================
model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String
  name          String
  phone         String?
  dateOfBirth   DateTime?
  gender        Gender?
  role          Role        @default(USER)
  avatar        String?
  isActive      Boolean     @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  screenings    Screening[]
  cigaretteLogs CigaretteLog[]
  
  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

// ============================================
// Screening Model
// ============================================
model Screening {
  id                    String          @id @default(cuid())
  userId                String
  
  // Input Parameters
  age                   Int
  isSmoker              Boolean         @default(false)
  smokingDurationYears  Float?
  isPassiveSmoker       Boolean?
  cigarettesPerDay      Int
  coughDuration         Float           // in months
  weight                Float           // in kg
  height                Float           // in cm
  bmi                   Float           // auto-calculated
  familyHistory         Boolean
  environmentalExposure Int             // scale 1-10
  chestPainScale        Int             // scale 1-10
  
  // AI Output
  riskScore             Float
  riskCategory          RiskCategory
  
  // Fuzzy Processing Details
  fuzzyInputs           Json?           // Fuzzified input values
  fuzzyRuleResults      Json?           // Rule evaluation results
  defuzzificationResult Json?           // Defuzzification details
  
  createdAt             DateTime        @default(now())
  
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations       Recommendation[]
  
  @@map("screenings")
}

enum RiskCategory {
  RENDAH
  SEDANG
  TINGGI
  SANGAT_TINGGI
}

// ============================================
// Recommendation Model
// ============================================
model Recommendation {
  id            String    @id @default(cuid())
  screeningId   String
  title         String
  description   String
  priority      Priority
  category      RecommendationCategory
  
  screening     Screening @relation(fields: [screeningId], references: [id], onDelete: Cascade)
  
  @@map("recommendations")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecommendationCategory {
  LIFESTYLE
  MEDICAL_CHECKUP
  DIET
  EXERCISE
  MENTAL_HEALTH
  EMERGENCY
}

// ============================================
// Fuzzy Rule Model
// ============================================
model FuzzyRule {
  id          String    @id @default(cuid())
  name        String
  conditions  Json      // Array of { variable, linguisticValue, operator }
  consequent  String    // Linguistic value for output (e.g., "rendah", "tinggi")
  weight      Float     @default(1.0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("fuzzy_rules")
}

// ============================================
// Fuzzy Variable Model
// ============================================
model FuzzyVariable {
  id                    String    @id @default(cuid())
  name                  String    @unique
  label                 String
  type                  VariableType
  minValue              Float
  maxValue              Float
  unit                  String?
  membershipFunctions   Json      // Array of { name, type, params }
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@map("fuzzy_variables")
}

enum VariableType {
  INPUT
  OUTPUT
}

// ============================================
// Knowledge Base Model
// ============================================
model KnowledgeBase {
  id          String    @id @default(cuid())
  title       String
  content     String
  summary     String?
  category    KBCategory
  tags        String
  imageUrl    String?
  isPublished Boolean   @default(false)
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("knowledge_base")
}

enum KBCategory {
  LUNG_CANCER
  SMOKING_RISKS
  PREVENTION
  EARLY_DETECTION
  TREATMENT
  LIFESTYLE
  RESEARCH
}

// ============================================
// Cigarette Tracker Model
// ============================================
model CigaretteLog {
  id        String   @id @default(cuid())
  userId    String
  count     Int
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("cigarette_logs")
}
